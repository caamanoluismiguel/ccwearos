# Firebase Realtime Database URL.
# Format: https://YOUR-PROJECT-default-rtdb.firebaseio.com
FIREBASE_DB_URL=

# Path to the Admin SDK service account JSON.
# Drop the file into ./secrets/ (gitignored) and leave this default.
FIREBASE_ADMIN_KEY_PATH=./secrets/firebase-admin-key.json

# Command the wrapper spawns. Defaults to `claude` (Claude Code CLI on PATH).
CLAUDE_CLI_COMMAND=claude

# Debounce window for metrics writes to Firebase (milliseconds).
# Per blueprint: never write per-chunk; default 5s.
METRICS_DEBOUNCE_MS=5000

# Max age (seconds) for a pending command before the wrapper drops it as stale.
# Per blueprint: prevents replaying a command after a Wi-Fi flap.
COMMAND_MAX_AGE_SECONDS=60
